rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isBootstrapAdminEmail() {
      return signedIn() && request.auth.token.email in ['Juka77@outlook.pt'];
    }

    function keepsProtectedUserFields() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['uid', 'email', 'role', 'createdAt'])
        && keepsLockedPhoneFields();
    }

    function hasExistingPhone() {
      return ('telefone' in resource.data)
        && resource.data.telefone is string
        && resource.data.telefone.size() > 0;
    }

    function keepsLockedPhoneFields() {
      return !hasExistingPhone()
        || !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['telefone', 'phoneVerified', 'phoneVerifiedAt']);
    }

    match /users/{userId} {
      allow create: if isOwner(userId)
        && (
          request.resource.data.role == 'cliente'
          || (request.resource.data.role == 'admin' && isBootstrapAdminEmail())
        );
      allow read: if isOwner(userId) || isAdmin();
      allow update: if isAdmin()
        || (isOwner(userId) && keepsProtectedUserFields())
        || (
          isOwner(userId)
          && isBootstrapAdminEmail()
          && request.resource.data.role == 'admin'
          && keepsLockedPhoneFields()
        );
      allow delete: if isAdmin();
    }

    match /menu/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /noticias/{newsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /app_settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /account_deletion_requests/{requestId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
    }

    match /moradas/{addressId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
    }

    match /drivers/{driverId} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn();
    }

    match /pedidos/{pedidoId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update: if signedIn();
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read, create: if signedIn();
        allow update, delete: if isAdmin();
      }

      match /delivery_messages/{messageId} {
        allow read, create: if signedIn();
        allow update, delete: if isAdmin();
      }
    }

    match /fechos_caixa/{fechoId} {
      allow read, write: if isAdmin();
    }

    match /user_favorites/{userId}/items/{itemId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /refund_requests/{requestId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow create: if signedIn();
      allow read, update, delete: if isAdmin();
    }

    match /support_tickets/{ticketId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      allow read, update: if isAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read, create: if isAdmin()
          || (
            signedIn()
            && get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.userId == request.auth.uid
          );
        allow update, delete: if isAdmin();
      }
    }
  }
}
